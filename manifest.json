{
  "manifest_version": 3,
  "name": "Tab Group to Markdown",
  "version": "1.0.0",
  "description": "Export Chrome Tab Groups to Markdown text or files for LLM contexts.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Export Tab Group"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabGroups",
    "tabs",
    "downloads"
  ]
}
